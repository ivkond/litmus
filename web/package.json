{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:views": "npx tsx src/db/migrate-views.ts",
    "db:setup": "npm run db:migrate && npm run db:views",
    "db:seed": "npx tsx src/db/seed.ts",
    "s3:test": "npx tsx src/lib/s3-smoke-test.ts",
    "pack": "npx tsx scripts/pack.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.0",
    "@aws-sdk/client-s3": "^3.1017.0",
    "adm-zip": "^0.5.16",
    "dockerode": "^4.0.10",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.1",
    "next": "16.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.8",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
